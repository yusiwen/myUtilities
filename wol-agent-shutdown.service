[Unit]
Description=WOL Agent Shutdown Notifier
DefaultDependencies=no
Before=shutdown.target
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
TimeoutStartSec=15
ExecStart=/usr/local/bin/mu wol agent --config=/etc/mu/wol-config.json --shutdown

[Install]
WantedBy=halt.target poweroff.target reboot.target
